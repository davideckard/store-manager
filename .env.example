# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# API token for worker/external access to /api/sites
API_TOKEN=changeme

# Orderboard credentials (used by the Python worker)
ORDERBOARD_API_URL=https://orderboard.example.com
ORDERBOARD_EMAIL=
ORDERBOARD_PASSWORD=

# App URL (used for internal API calls from the worker)
STORE_MANAGER_URL=http://localhost:3000
